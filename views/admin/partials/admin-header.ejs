<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> | Admin — Baliraja Academy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/admin.css"/>
</head>
<body class="admin-body">

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <span class="sidebar-logo">🎓</span>
    <div>
      <p class="sidebar-title">Baliraja Academy</p>
      <p class="sidebar-role">Admin Panel</p>
    </div>
    <button class="sidebar-close" id="sidebarClose"><i class="fas fa-times"></i></button>
  </div>

  <nav class="sidebar-nav">
    <a href="/admin/dashboard" class="nav-item <%= title==='Dashboard'?'active':'' %>">
      <i class="fas fa-tachometer-alt"></i> Dashboard
    </a>
    <div class="nav-section">Content</div>
    <a href="/admin/students" class="nav-item <%= title.includes('Student')?'active':'' %>">
      <i class="fas fa-user-graduate"></i> Students
    </a>
    <a href="/admin/alumni" class="nav-item <%= title.includes('Alumni')?'active':'' %>">
      <i class="fas fa-users"></i> Alumni
    </a>
    <a href="/admin/users" class="nav-item <%= title.includes('User')?'active':'' %>">
      <i class="fas fa-user-check"></i> User Approvals
    </a>
    <a href="/admin/faculty" class="nav-item <%= title.includes('Faculty')?'active':'' %>">
      <i class="fas fa-chalkboard-teacher"></i> Faculty
    </a>
    <a href="/admin/results" class="nav-item <%= title.includes('Result')?'active':'' %>">
      <i class="fas fa-trophy"></i> Results
    </a>
    <div class="nav-section">Media</div>
    <a href="/admin/gallery" class="nav-item <%= title.includes('Gallery')?'active':'' %>">
      <i class="fas fa-images"></i> Gallery
    </a>
    <div class="nav-section">Communicate</div>
    <a href="/admin/notices" class="nav-item <%= title.includes('Notice')?'active':'' %>">
      <i class="fas fa-bell"></i> Notices
    </a>
    <a href="/admin/contacts" class="nav-item <%= title.includes('Contact')?'active':'' %>">
      <i class="fas fa-envelope"></i> Messages
    </a>
    <div class="nav-section">System</div>
    <a href="/" class="nav-item" target="_blank">
      <i class="fas fa-external-link-alt"></i> View Website
    </a>
    <a href="/admin/logout" class="nav-item nav-logout">
      <i class="fas fa-sign-out-alt"></i> Logout
    </a>
  </nav>
</aside>

<!-- Main Content -->
<div class="admin-main" id="adminMain">
  <!-- Top Bar -->
  <header class="admin-topbar">
    <button class="topbar-toggle" id="sidebarToggle">
      <i class="fas fa-bars"></i>
    </button>
    <div class="topbar-title"><%= title %></div>
    <div class="topbar-right">
      <span class="topbar-user"><i class="fas fa-user-shield"></i> Admin</span>
      <a href="/admin/logout" class="topbar-logout"><i class="fas fa-power-off"></i></a>
    </div>
  </header>

  <!-- Flash Messages -->
  <% if (messages && messages.success && messages.success.length) { %>
  <div class="admin-alert admin-alert-success">
    <i class="fas fa-check-circle"></i> <%= messages.success[0] %>
    <button onclick="this.parentElement.remove()">✕</button>
  </div>
  <% } %>
  <% if (messages && messages.error && messages.error.length) { %>
  <div class="admin-alert admin-alert-danger">
    <i class="fas fa-exclamation-triangle"></i> <%= messages.error[0] %>
    <button onclick="this.parentElement.remove()">✕</button>
  </div>
  <% } %>

  <div class="admin-content">
