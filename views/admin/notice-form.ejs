<%- include('layout') %>
<div class="admin-card form-card">
  <div class="admin-card-header">
    <h3><i class="fas fa-<%= notice ? 'edit' : 'plus' %>"></i> <%= notice ? 'Edit' : 'Add' %> Notice</h3>
    <a href="/admin/notices" class="btn-sm-admin"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
  <form method="POST" action="<%= action %>" class="admin-form">
    <div class="form-group">
      <label>Notice Title *</label>
      <input type="text" name="title" value="<%= notice ? notice.title : '' %>" placeholder="Notice title" required />
    </div>
    <div class="form-group">
      <label>Description *</label>
      <textarea name="description" rows="6" placeholder="Notice details..." required><%= notice ? notice.description : '' %></textarea>
    </div>
    <div class="form-group">
      <label>Date</label>
      <input type="date" name="date" value="<%= notice ? new Date(notice.date).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>" />
    </div>
    <button type="submit" class="btn-admin-primary"><i class="fas fa-save"></i> <%= notice ? 'Update' : 'Publish' %> Notice</button>
  </form>
</div>
<%- include('layout-end') %>
