<%- include('layout') %>
<div class="admin-card form-card">
  <div class="admin-card-header">
    <h3><i class="fas fa-<%= alumni ? 'edit' : 'plus' %>"></i> <%= alumni ? 'Edit' : 'Add' %> Alumni</h3>
    <a href="/admin/alumni" class="btn-sm-admin"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
  <form method="POST" action="<%= action %>" enctype="multipart/form-data" class="admin-form">
    <div class="form-row">
      <div class="form-group">
        <label>Full Name *</label>
        <input type="text" name="name" value="<%= alumni ? alumni.name : '' %>" required />
      </div>
      <div class="form-group">
        <label>Batch Year *</label>
        <input type="text" name="batch" value="<%= alumni ? alumni.batch : '' %>" placeholder="e.g. 2022-2023" required />
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>College Name</label>
        <input type="text" name="college" value="<%= alumni ? alumni.college : '' %>" placeholder="College / University" />
      </div>
      <div class="form-group">
        <label>Branch / Course</label>
        <input type="text" name="branch" value="<%= alumni ? alumni.branch : '' %>" placeholder="e.g. B.Tech Computer Science" />
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Current Status</label>
        <input type="text" name="currentStatus" value="<%= alumni ? alumni.currentStatus : '' %>" placeholder="e.g. Software Engineer at TCS" />
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="text" name="phone" value="<%= alumni ? alumni.phone || '' : '' %>" placeholder="Mobile number" />
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Login Email <small>(for alumni portal access)</small></label>
        <input type="email" name="email" value="<%= alumni ? alumni.email || '' : '' %>" placeholder="alumni@email.com" />
      </div>
      <div class="form-group">
        <label>Password <small><%= alumni ? '(leave blank to keep current)' : '(for alumni portal)' %></small></label>
        <input type="password" name="password" placeholder="Min 6 characters" />
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Photo</label>
        <input type="file" name="photo" accept="image/*" />
        <% if (alumni && alumni.photo) { %><img src="/uploads/<%= alumni.photo %>" class="preview-img" /><% } %>
      </div>
    </div>
    <button type="submit" class="btn-admin-primary"><i class="fas fa-save"></i> <%= alumni ? 'Update' : 'Add' %> Alumni</button>
  </form>
</div>
<%- include('layout-end') %>
