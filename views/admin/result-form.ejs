<%- include('layout') %>
<div class="admin-card form-card">
  <div class="admin-card-header">
    <h3><i class="fas fa-<%= result ? 'edit' : 'plus' %>"></i> <%= result ? 'Edit' : 'Add' %> Result</h3>
    <a href="/admin/results" class="btn-sm-admin"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
  <form method="POST" action="<%= action %>" class="admin-form">
    <div class="form-row">
      <div class="form-group">
        <label>Student Name *</label>
        <input type="text" name="studentName" value="<%= result ? result.studentName : '' %>" required />
      </div>
      <div class="form-group">
        <label>Examination *</label>
        <input type="text" name="exam" value="<%= result ? result.exam : '' %>" placeholder="e.g. HSC Board 2024" required />
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Percentage *</label>
        <input type="number" name="percentage" value="<%= result ? result.percentage : '' %>" min="0" max="100" step="0.01" required />
      </div>
      <div class="form-group">
        <label>Rank</label>
        <input type="text" name="rank" value="<%= result ? result.rank : '' %>" placeholder="e.g. District Topper" />
      </div>
    </div>
    <div class="form-group">
      <label>Year *</label>
      <input type="text" name="year" value="<%= result ? result.year : '' %>" placeholder="e.g. 2024" required />
    </div>
    <button type="submit" class="btn-admin-primary"><i class="fas fa-save"></i> <%= result ? 'Update' : 'Add' %> Result</button>
  </form>
</div>
<%- include('layout-end') %>
