<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login | Baliraja Career Academy</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="login-body">
  <div class="login-container">
    <div class="login-card">
      <div class="login-logo">
        <div class="brand-icon large">B</div>
        <h2>Baliraja Career Academy</h2>
        <p>Admin Panel</p>
      </div>
      <% if (error && error.length > 0) { %>
        <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
      <% } %>
      <form method="POST" action="/admin/login" class="login-form">
        <div class="form-group">
          <label><i class="fas fa-envelope"></i> Email Address</label>
          <input type="email" name="email" placeholder="admin@baliraja.com" required autofocus />
        </div>
        <div class="form-group">
          <label><i class="fas fa-lock"></i> Password</label>
          <input type="password" name="password" placeholder="Enter your password" required />
        </div>
        <button type="submit" class="btn-login">Login <i class="fas fa-arrow-right"></i></button>
      </form>
      <a href="/" class="back-link"><i class="fas fa-home"></i> Back to Website</a>
    </div>
  </div>
</body>
</html>
