<%- include('layout') %>
<% if (success && success.length) { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>
<% if (error && error.length) { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>
<div class="admin-card">
  <div class="admin-card-header">
    <h3><i class="fas fa-user-graduate"></i> All Students (<%= students.length %>)</h3>
    <a href="/admin/students/add" class="btn-admin-primary"><i class="fas fa-plus"></i> Add Student</a>
  </div>
  <% if (students.length === 0) { %>
    <p class="empty-msg">No students added yet.</p>
  <% } else { %>
  <table class="admin-table">
    <thead><tr><th>Photo</th><th>Name</th><th>Class</th><th>Stream</th><th>Village</th><th>District</th><th>Actions</th></tr></thead>
    <tbody>
      <% students.forEach(s => { %>
      <tr>
        <td><div class="table-avatar"><% if(s.photo){ %><img src="/uploads/<%= s.photo %>" /><% } else { %><i class="fas fa-user"></i><% } %></div></td>
        <td><strong><%= s.name %></strong></td>
        <td><span class="class-badge"><%= s.class %></span></td>
        <td><%= s.stream %></td>
        <td><%= s.village || '—' %></td>
        <td><%= s.district || '—' %></td>
        <td class="actions">
          <a href="/admin/students/edit/<%= s._id %>" class="btn-edit"><i class="fas fa-edit"></i></a>
          <form method="POST" action="/admin/students/delete/<%= s._id %>" style="display:inline" onsubmit="return confirm('Delete this student?')">
            <button type="submit" class="btn-delete"><i class="fas fa-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('layout-end') %>
