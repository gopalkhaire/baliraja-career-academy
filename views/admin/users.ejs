<%- include('layout') %>

<% if (success && success.length > 0) { %>
  <div class="admin-alert admin-alert-success"><i class="fas fa-check-circle"></i> <%= success[0] %> <button onclick="this.parentElement.remove()">✕</button></div>
<% } %>
<% if (error && error.length > 0) { %>
  <div class="admin-alert admin-alert-danger"><i class="fas fa-exclamation-triangle"></i> <%= error[0] %> <button onclick="this.parentElement.remove()">✕</button></div>
<% } %>

<!-- Tabs -->
<div class="user-tabs">
  <button class="utab active" onclick="showTab('pending',this)">
    <i class="fas fa-clock"></i> Pending Requests
    <span class="utab-count pending-c"><%= pending.length %></span>
  </button>
  <button class="utab" onclick="showTab('students',this)">
    <i class="fas fa-user-graduate"></i> Approved Students
    <span class="utab-count approved-c"><%= approvedStudents.length %></span>
  </button>
  <button class="utab" onclick="showTab('alumni',this)">
    <i class="fas fa-user-tie"></i> Approved Alumni
    <span class="utab-count approved-c"><%= approvedAlumni.length %></span>
  </button>
  <button class="utab" onclick="showTab('rejected',this)">
    <i class="fas fa-times-circle"></i> Rejected
    <span class="utab-count rejected-c"><%= rejected.length %></span>
  </button>
</div>

<!-- ── PENDING ─────────────────────────────────────────────────────────── -->
<div id="tab-pending" class="utab-panel">
  <% if (pending.length === 0) { %>
    <div class="admin-card" style="padding:2.5rem;text-align:center;">
      <i class="fas fa-check-double" style="font-size:2.5rem;color:#4caf50;margin-bottom:1rem;display:block;"></i>
      <p style="color:#666;font-size:1rem;">No pending requests — all caught up!</p>
    </div>
  <% } else { %>
  <div class="users-approval-grid">
    <% pending.forEach(u => { %>
    <div class="ucard">
      <div class="ucard-top">
        <div class="ucard-avatar <%= u.requestedRole %>">
          <% if (u.photo) { %>
            <img src="/uploads/<%= u.photo %>" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
          <% } else { %>
            <i class="fas fa-<%= u.requestedRole === 'student' ? 'user-graduate' : 'user-tie' %>"></i>
          <% } %>
        </div>
        <div class="ucard-info">
          <h4><%= u.name %></h4>
          <p class="ucard-email"><i class="fas fa-envelope"></i> <%= u.email %></p>
          <% if (u.phone) { %><p class="ucard-email"><i class="fas fa-phone"></i> <%= u.phone %></p><% } %>
          <span class="ucard-role-badge <%= u.requestedRole %>">
            <%= u.requestedRole === 'student' ? '🎓 Student Request' : '🏆 Alumni Request' %>
          </span>
        </div>
      </div>
      <div class="ucard-details">
        <% if (u.requestedRole === 'student') { %>
          <% if (u.class) { %><span><i class="fas fa-graduation-cap"></i> Class <%= u.class %> — <%= u.stream %></span><% } %>
          <% if (u.village) { %><span><i class="fas fa-map-marker-alt"></i> <%= u.village %><%= u.district ? ', '+u.district : '' %></span><% } %>
        <% } else { %>
          <% if (u.batch)   { %><span><i class="fas fa-calendar"></i> Batch: <%= u.batch %></span><% } %>
          <% if (u.college) { %><span><i class="fas fa-university"></i> <%= u.college %></span><% } %>
          <% if (u.currentStatus) { %><span><i class="fas fa-briefcase"></i> <%= u.currentStatus %></span><% } %>
        <% } %>
        <span class="ucard-date"><i class="fas fa-clock"></i> Applied: <%= new Date(u.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
      </div>
      <div class="approve-note">
        <i class="fas fa-info-circle"></i>
        Approving will <strong>move</strong> this user to the official
        <%= u.requestedRole === 'student' ? 'Students' : 'Alumni' %> list and remove this request.
      </div>
      <div class="ucard-actions">
        <form action="/admin/users/approve/<%= u._id %>" method="POST" style="flex:1">
          <button class="btn-admin-approve btn-full"><i class="fas fa-check"></i> Approve & Move</button>
        </form>
        <button class="btn-admin-reject" onclick="showReject('<%= u._id %>','<%= u.name %>')"><i class="fas fa-times"></i> Reject</button>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<!-- ── APPROVED STUDENTS ──────────────────────────────────────────────────── -->
<div id="tab-students" class="utab-panel" style="display:none">
  <% if (approvedStudents.length === 0) { %>
    <div class="admin-card" style="padding:2rem;text-align:center;"><p style="color:#666;">No approved students via portal yet.</p></div>
  <% } else { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Photo</th><th>Name</th><th>Email</th><th>Class</th><th>Stream</th><th>Village</th><th>Approved On</th><th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% approvedStudents.forEach(s => { %>
      <tr>
        <td>
          <% if (s.photo) { %>
            <img src="/uploads/<%= s.photo %>" style="width:40px;height:40px;border-radius:50%;object-fit:cover;" />
          <% } else { %>
            <div style="width:40px;height:40px;border-radius:50%;background:#e3f2fd;display:flex;align-items:center;justify-content:center;color:#1565c0;"><i class="fas fa-user-graduate"></i></div>
          <% } %>
        </td>
        <td><strong><%= s.name %></strong></td>
        <td><%= s.email %></td>
        <td><%= s.class || '—' %></td>
        <td><%= s.stream || '—' %></td>
        <td><%= s.village || '—' %><%= s.district ? ', '+s.district : '' %></td>
        <td><%= s.approvedAt ? new Date(s.approvedAt).toLocaleDateString('en-IN') : '—' %></td>
        <td>
          <a href="/admin/students/edit/<%= s._id %>" class="btn-sm-admin" title="Edit"><i class="fas fa-edit"></i></a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <div style="margin-top:1rem;text-align:right;">
    <a href="/admin/students" class="btn-sm-admin"><i class="fas fa-external-link-alt"></i> Full Students List</a>
  </div>
  <% } %>
</div>

<!-- ── APPROVED ALUMNI ────────────────────────────────────────────────────── -->
<div id="tab-alumni" class="utab-panel" style="display:none">
  <% if (approvedAlumni.length === 0) { %>
    <div class="admin-card" style="padding:2rem;text-align:center;"><p style="color:#666;">No approved alumni via portal yet.</p></div>
  <% } else { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Photo</th><th>Name</th><th>Email</th><th>Batch</th><th>College</th><th>Status</th><th>Approved On</th><th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% approvedAlumni.forEach(a => { %>
      <tr>
        <td>
          <% if (a.photo) { %>
            <img src="/uploads/<%= a.photo %>" style="width:40px;height:40px;border-radius:50%;object-fit:cover;" />
          <% } else { %>
            <div style="width:40px;height:40px;border-radius:50%;background:#f3e5f5;display:flex;align-items:center;justify-content:center;color:#6a1b9a;"><i class="fas fa-user-tie"></i></div>
          <% } %>
        </td>
        <td><strong><%= a.name %></strong></td>
        <td><%= a.email %></td>
        <td><%= a.batch || '—' %></td>
        <td><%= a.college || '—' %></td>
        <td><%= a.currentStatus || '—' %></td>
        <td><%= a.approvedAt ? new Date(a.approvedAt).toLocaleDateString('en-IN') : '—' %></td>
        <td>
          <a href="/admin/alumni/edit/<%= a._id %>" class="btn-sm-admin" title="Edit"><i class="fas fa-edit"></i></a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <div style="margin-top:1rem;text-align:right;">
    <a href="/admin/alumni" class="btn-sm-admin"><i class="fas fa-external-link-alt"></i> Full Alumni List</a>
  </div>
  <% } %>
</div>

<!-- ── REJECTED ───────────────────────────────────────────────────────────── -->
<div id="tab-rejected" class="utab-panel" style="display:none">
  <% if (rejected.length === 0) { %>
    <div class="admin-card" style="padding:2rem;text-align:center;"><p style="color:#666;">No rejected requests.</p></div>
  <% } else { %>
  <table class="admin-table">
    <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Reason</th><th>Applied</th><th>Actions</th></tr></thead>
    <tbody>
      <% rejected.forEach(u => { %>
      <tr>
        <td><strong><%= u.name %></strong></td>
        <td><%= u.email %></td>
        <td><span class="ucard-role-badge <%= u.requestedRole %>"><%= u.requestedRole %></span></td>
        <td><em style="color:#888"><%= u.rejectedReason || 'No reason given' %></em></td>
        <td><%= new Date(u.createdAt).toLocaleDateString('en-IN') %></td>
        <td style="display:flex;gap:.4rem;">
          <form action="/admin/users/approve/<%= u._id %>" method="POST">
            <button class="btn-sm-admin" title="Re-approve this request"><i class="fas fa-redo"></i> Re-approve</button>
          </form>
          <form action="/admin/users/delete/<%= u._id %>" method="POST" onsubmit="return confirm('Permanently delete this request?')">
            <button class="btn-sm-del"><i class="fas fa-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<!-- ── REJECT MODAL ───────────────────────────────────────────────────────── -->
<div id="rejectModal" class="modal-overlay" style="display:none">
  <div class="modal-box">
    <h3><i class="fas fa-times-circle"></i> Reject Request</h3>
    <p>Rejecting <strong id="rejectName"></strong>'s account request. They will receive an email notification.</p>
    <form id="rejectForm" method="POST">
      <div class="form-group">
        <label>Reason <small>(optional — will be included in notification email)</small></label>
        <textarea name="reason" class="form-control" rows="3" placeholder="e.g. Could not verify enrollment details..."></textarea>
      </div>
      <div class="modal-actions">
        <button type="button" onclick="closeReject()" class="btn-sm-admin"><i class="fas fa-times"></i> Cancel</button>
        <button type="submit" class="btn-admin-reject"><i class="fas fa-ban"></i> Confirm Rejection</button>
      </div>
    </form>
  </div>
</div>

<style>
.approve-note {
  background: #e8f5e9; border: 1px solid #c8e6c9; border-radius: 8px;
  padding: 0.6rem 0.8rem; font-size: 0.82rem; color: #2e7d32;
  margin-bottom: 0.75rem; display: flex; align-items: flex-start; gap: 0.5rem;
}
</style>

<script>
function showTab(tab, btn) {
  document.querySelectorAll('.utab-panel').forEach(p => p.style.display = 'none');
  document.querySelectorAll('.utab').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + tab).style.display = '';
  btn.classList.add('active');
}
function showReject(id, name) {
  document.getElementById('rejectName').textContent = name;
  document.getElementById('rejectForm').action = '/admin/users/reject/' + id;
  document.getElementById('rejectModal').style.display = 'flex';
}
function closeReject() { document.getElementById('rejectModal').style.display = 'none'; }
</script>

<%- include('layout-end') %>
