<%- include('layout') %>
<div class="admin-card form-card">
  <div class="admin-card-header">
    <h3><i class="fas fa-<%= faculty ? 'edit' : 'plus' %>"></i> <%= faculty ? 'Edit' : 'Add' %> Faculty</h3>
    <a href="/admin/faculty" class="btn-sm-admin"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
  <form method="POST" action="<%= action %>" enctype="multipart/form-data" class="admin-form">
    <div class="form-row">
      <div class="form-group">
        <label>Full Name *</label>
        <input type="text" name="name" value="<%= faculty ? faculty.name : '' %>" required />
      </div>
      <div class="form-group">
        <label>Subject *</label>
        <input type="text" name="subject" value="<%= faculty ? faculty.subject : '' %>" placeholder="e.g. Physics" required />
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Qualification</label>
        <input type="text" name="qualification" value="<%= faculty ? faculty.qualification : '' %>" placeholder="e.g. M.Sc Physics, B.Ed" />
      </div>
      <div class="form-group">
        <label>Experience</label>
        <input type="text" name="experience" value="<%= faculty ? faculty.experience : '' %>" placeholder="e.g. 10 years" />
      </div>
    </div>
    <div class="form-group">
      <label>Photo</label>
      <input type="file" name="photo" accept="image/*" />
      <% if (faculty && faculty.photo) { %><img src="/uploads/<%= faculty.photo %>" class="preview-img" /><% } %>
    </div>
    <button type="submit" class="btn-admin-primary"><i class="fas fa-save"></i> <%= faculty ? 'Update' : 'Add' %> Faculty</button>
  </form>
</div>
<%- include('layout-end') %>
