<%- include('partials/admin-header') %>
<div class="page-header">
  <div><h2>Upload Gallery Image</h2></div>
  <a href="/admin/gallery" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="form-card">
  <form action="/admin/gallery/add" method="POST" enctype="multipart/form-data" class="admin-form">
    <div class="form-group">
      <label>Image Title *</label>
      <input type="text" name="title" required placeholder="e.g. Annual Day Celebration 2024"/>
    </div>
    <div class="form-group">
      <label>Category</label>
      <select name="category">
        <option value="Event">Event</option>
        <option value="Academic">Academic</option>
        <option value="Seminar">Seminar</option>
        <option value="Function">Function</option>
        <option value="Other">Other</option>
      </select>
    </div>
    <div class="form-group">
      <label>Image File *</label>
      <input type="file" name="image" accept="image/*" required/>
      <small>Max size: 5MB. Formats: JPG, PNG, GIF, WebP</small>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-submit"><i class="fas fa-upload"></i> Upload Image</button>
      <a href="/admin/gallery" class="btn-cancel">Cancel</a>
    </div>
  </form>
</div>
<%- include('partials/admin-footer') %>
