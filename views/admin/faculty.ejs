<%- include('layout') %>
<% if (success && success.length) { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>
<% if (error && error.length) { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>
<div class="admin-card">
  <div class="admin-card-header">
    <h3><i class="fas fa-chalkboard-teacher"></i> Faculty (<%= faculty.length %>)</h3>
    <a href="/admin/faculty/add" class="btn-admin-primary"><i class="fas fa-plus"></i> Add Faculty</a>
  </div>
  <% if (faculty.length === 0) { %><p class="empty-msg">No faculty added yet.</p>
  <% } else { %>
  <table class="admin-table">
    <thead><tr><th>Photo</th><th>Name</th><th>Subject</th><th>Qualification</th><th>Experience</th><th>Actions</th></tr></thead>
    <tbody>
      <% faculty.forEach(f => { %>
      <tr>
        <td><div class="table-avatar"><% if(f.photo){ %><img src="/uploads/<%= f.photo %>" /><% } else { %><i class="fas fa-user-tie"></i><% } %></div></td>
        <td><strong><%= f.name %></strong></td>
        <td><%= f.subject %></td>
        <td><%= f.qualification || '—' %></td>
        <td><%= f.experience || '—' %></td>
        <td class="actions">
          <a href="/admin/faculty/edit/<%= f._id %>" class="btn-edit"><i class="fas fa-edit"></i></a>
          <form method="POST" action="/admin/faculty/delete/<%= f._id %>" style="display:inline" onsubmit="return confirm('Delete?')">
            <button type="submit" class="btn-delete"><i class="fas fa-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('layout-end') %>
