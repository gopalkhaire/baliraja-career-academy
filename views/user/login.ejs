<%- include('../partials/header') %>

<div class="auth-page-wrap">
  <div class="auth-split-left">
    <div class="auth-brand-panel">
      <div class="auth-brand-icon">B</div>
      <h1>Baliraja Career Academy</h1>
      <p>Empowering students from rural Maharashtra with quality education and a path to a brighter future.</p>
      <div class="auth-features">
        <div class="af-item"><i class="fas fa-check-circle"></i> Access your results & notices</div>
        <div class="af-item"><i class="fas fa-check-circle"></i> View your profile & progress</div>
        <div class="af-item"><i class="fas fa-check-circle"></i> Connect with alumni network</div>
      </div>
    </div>
  </div>
  <div class="auth-split-right">
    <div class="auth-box">
      <div class="auth-box-header">
        <h2>Welcome Back</h2>
        <p>Sign in to your student or alumni account</p>
      </div>

      <% if (messages.error && messages.error.length > 0) { %>
        <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= messages.error[0] %></div>
      <% } %>
      <% if (messages.success && messages.success.length > 0) { %>
        <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= messages.success[0] %></div>
      <% } %>

      <form action="/login" method="POST" class="auth-form">
        <div class="form-group">
          <label><i class="fas fa-envelope"></i> Email Address</label>
          <br>
          <input type="email" name="email" class="form-control" placeholder="your@email.com" required autofocus />
        </div>
        <div class="form-group">
          <label><i class="fas fa-lock"></i> Password</label>
          <div class="password-wrap">
            <input type="password" name="password" id="loginPass" class="form-control" placeholder="Enter your password" required />
            <button type="button" class="eye-btn" onclick="togglePass('loginPass',this)"><i class="fas fa-eye"></i></button>
          </div>
        </div>
        <div class="form-footer-row">
          <a href="/forgot-password" class="forgot-link">Forgot password?</a>
        </div>
        <button type="submit" class="btn btn-primary btn-full"><i class="fas fa-sign-in-alt"></i> Sign In</button>
      </form>

      <div class="auth-divider"><span>New here?</span></div>
      <a href="/register" class="btn btn-outline btn-full"><i class="fas fa-user-plus"></i> Create an Account</a>

      <div class="auth-admin-link">
        Admin? <a href="/admin/login">Admin Login →</a>
      </div>
    </div>
  </div>
</div>

<script>
function togglePass(id, btn) {
  const inp = document.getElementById(id);
  inp.type = inp.type === 'password' ? 'text' : 'password';
  btn.querySelector('i').className = inp.type === 'password' ? 'fas fa-eye' : 'fas fa-eye-slash';
}
</script>

<%- include('../partials/footer') %>
