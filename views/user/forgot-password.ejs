<%- include('../partials/header') %>
<div class="page-hero"><div class="container"><h1>Forgot Password</h1><p>We'll send a reset link to your email</p></div></div>
<section class="section">
  <div class="container">
    <div class="auth-container">
      <% if (messages.error && messages.error.length > 0) { %>
        <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= messages.error[0] %></div>
      <% } %>
      <% if (messages.success && messages.success.length > 0) { %>
        <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= messages.success[0] %></div>
      <% } %>
      <div class="auth-card">
        <div class="auth-header">
          <div class="auth-icon"><i class="fas fa-key"></i></div>
          <h2>Reset Password</h2>
          <p>Enter your registered email address</p>
        </div>
        <form action="/forgot-password" method="POST" class="auth-form">
          <div class="form-group">
            <label><i class="fas fa-envelope"></i> Email Address</label>
            <input type="email" name="email" class="form-control" placeholder="your@email.com" required autofocus />
          </div>
          <button type="submit" class="btn btn-primary btn-full"><i class="fas fa-paper-plane"></i> Send Reset Link</button>
        </form>
        <div class="auth-footer"><a href="/login"><i class="fas fa-arrow-left"></i> Back to Login</a></div>
      </div>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
